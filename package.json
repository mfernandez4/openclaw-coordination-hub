{
  "name": "openclaw-coordination-hub",
  "version": "0.1.0",
  "description": "Real-time coordination layer for OpenClaw sub-agent orchestration",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "npm run test:unit",
    "test:unit": "npx vitest run --config vitest.config.mjs",
    "test:integration": "npx vitest run --config vitest.integration.config.mjs",
    "test:watch": "npx vitest --config vitest.config.mjs",
    "test:coverage": "npx vitest run --config vitest.config.mjs --coverage"
  },
  "dependencies": {
    "ioredis": "^5.3.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "ioredis-mock": "^8.13.1",
    "vitest": "^4.1.2"
  }
}
