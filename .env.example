# Redis connection
REDIS_HOST=redis
REDIS_PORT=6379

# Logging (trace|debug|info|warn|error|fatal)
LOG_LEVEL=info

# Health check server
HEALTH_PORT=3001

# Mem0 long-term memory (disabled by default)
MEM0_ENABLED=false
MEM0_API_KEY=
MEM0_BASE_URL=http://localhost:8000

# OpenClaw memory system path (local journal.jsonl bridge)
OPENCLAW_MEMORY_BASE=/path/to/openclaw-memory-system-v1/.memory-system

# Brave Search API (research worker)
BRAVE_SEARCH_API_KEY=

# Shared artifact directory for inter-worker file exchange
SHARED_ARTIFACT_PATH=./shared/artifacts
